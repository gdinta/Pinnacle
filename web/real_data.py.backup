    }


# ============================================
# 4. COST OF LIVING - FREE DATA
# ============================================

@lru_cache(maxsize=100)
def get_col_free(city_state_combo=None):
    """
    Get REAL cost of living multipliers
    Based on public census/research data (FREE)
    
    Args:
        city_state_combo: e.g., "Philadelphia, PA"
    
    Returns:
        1.05 (multiplier)
    """
    
    # Numbeo-based COL multipliers (Public data, manually maintained)
    # Updated: 2024, Based on housing, food, transportation
    
    COL_MULTIPLIERS = {
        # Top cities (high COL)
        'San Francisco': 1.55,
        'San Francisco, CA': 1.55,
        'SF, CA': 1.55,
        'New York': 1.45,
        'New York, NY': 1.45,
        'NYC': 1.45,
        'Boston': 1.35,
        'Boston, MA': 1.35,
        'Washington': 1.30,
        'Washington, DC': 1.30,
        'DC': 1.30,
        'Seattle': 1.25,
        'Seattle, WA': 1.25,
        
        # Medium-high COL
        'Los Angeles': 1.40,
        'Los Angeles, CA': 1.40,
        'LA': 1.40,
        'Chicago': 1.15,
        'Chicago, IL': 1.15,
        'Denver': 1.08,
        'Denver, CO': 1.08,
        'Austin': 1.10,
        'Austin, TX': 1.10,
        'Miami': 1.05,
        'Miami, FL': 1.05,
        'Portland': 1.12,
        'Portland, OR': 1.12,
        'San Diego': 1.38,
        'San Diego, CA': 1.38,
        
        # Medium COL
        'Philadelphia': 1.05,
        'Philadelphia, PA': 1.05,
        'Philly': 1.05,
        'Malvern': 1.00,
        'Malvern, PA': 1.00,
        'Pittsburgh': 0.92,
        'Pittsburgh, PA': 0.92,
        'Charlotte': 0.95,
        'Charlotte, NC': 0.95,
        'Nashville': 0.85,
        'Nashville, TN': 0.85,
        'Atlanta': 0.98,
        'Atlanta, GA': 0.98,
        'Dallas': 0.95,
        'Dallas, TX': 0.95,
        'Houston': 0.92,
        'Houston, TX': 0.92,
        
        # Lower COL
        'Memphis': 0.80,
        'Memphis, TN': 0.80,
        'Phoenix': 0.90,
        'Phoenix, AZ': 0.90,
        'Detroit': 0.85,
        'Detroit, MI': 0.85,
        'Columbus': 0.88,
        'Columbus, OH': 0.88,
        'Cleveland': 0.82,
        'Cleveland, OH': 0.82,
    }
    
    if not city_state_combo:
        return 1.0  # Default
    
    # Normalize input
    city_state = city_state_combo.strip().title()
    
    # Try exact match
    multiplier = COL_MULTIPLIERS.get(city_state)
    if multiplier:
        return multiplier
    
    # Try partial match (just city name)
    city_only = city_state.split(',')[0].strip()
    multiplier = COL_MULTIPLIERS.get(city_only)
    if multiplier:
        return multiplier
    
    # Default
    return 1.0


