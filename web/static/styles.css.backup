/* ============================================
   WealthPath AI - Enhanced CSS Styling
   Dark Fintech Theme with 10 Interactive Features
   ============================================ */

:root {
    /* Color Palette */
    --bg-primary: #0f172a;
    --bg-secondary: #1e293b;
    --bg-tertiary: #334155;
    --text-primary: #f1f5f9;
    --text-secondary: #cbd5e1;
    --text-tertiary: #94a3b8;
    
    /* Accent Colors */
    --accent-green: #10b981;
    --accent-blue: #3b82f6;
    --accent-teal: #06b6d4;
    --accent-orange: #f59e0b;
    --accent-red: #ef4444;
    
    /* Functional Colors */
    --success: #10b981;
    --warning: #f59e0b;
    --danger: #ef4444;
    --info: #3b82f6;
    
    /* Spacing */
    --spacing-xs: 0.25rem;
    --spacing-sm: 0.5rem;
    --spacing-md: 1rem;
    --spacing-lg: 1.5rem;
    --spacing-xl: 2rem;
    --spacing-2xl: 3rem;
    
    /* Border Radius */
    --radius-sm: 0.375rem;
    --radius-md: 0.5rem;
    --radius-lg: 0.75rem;
    --radius-xl: 1rem;
    
    /* Shadows */
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
    --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.3);
    
    /* Transitions */
    --transition-fast: 150ms ease-in-out;
    --transition-normal: 250ms ease-in-out;
    --transition-slow: 350ms ease-in-out;
}

/* Light Mode */
:root.light-mode {
    --bg-primary: #f8f9fa;
    --bg-secondary: #ffffff;
    --bg-tertiary: #e9ecef;
    --text-primary: #1e293b;
    --text-secondary: #475569;
    --text-tertiary: #64748b;
}

/* ============================================
   Reset & Base Styles
   ============================================ */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    font-size: 16px;
    transition: background-color var(--transition-normal), color var(--transition-normal);
}

/* ============================================
   Typography
   ============================================ */

h1, h2, h3, h4, h5, h6 {
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: var(--spacing-md);
}

h1 { font-size: 2.5rem; }
h2 { font-size: 2rem; }
h3 { font-size: 1.5rem; }
h4 { font-size: 1.25rem; }
h5 { font-size: 1.1rem; }
h6 { font-size: 1rem; }

p {
    margin-bottom: var(--spacing-md);
    color: var(--text-secondary);
}

a {
    color: var(--accent-blue);
    text-decoration: none;
    transition: color var(--transition-fast);
}

a:hover {
    color: var(--accent-teal);
}

/* ============================================
   Container & Layout
   ============================================ */

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--spacing-xl);
}

section {
    margin-bottom: var(--spacing-2xl);
}

/* ============================================
   Navigation & Header
   ============================================ */

.navbar {
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
    border-bottom: 2px solid var(--accent-blue);
    padding: var(--spacing-xl) 0;
    box-shadow: var(--shadow-lg);
    margin-bottom: var(--spacing-2xl);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: all var(--transition-normal);
}

.navbar-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    align-items: center;
}

/* ============================================
   LOGO STYLING - ENHANCED
   ============================================ */

.logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-content: center;
    animation: fadeInLogo 0.8s ease-out;
}

@keyframes fadeInLogo {
    from {
        opacity: 0;
        transform: scale(0.9) translateY(-10px);
    }
    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

.logo-img {
    height: 90px;
    width: auto;
    filter: drop-shadow(0 8px 16px rgba(16, 185, 129, 0.25));
    transition: all var(--transition-normal);
}

.logo-img:hover {
    transform: scale(1.1) rotate(2deg);
    filter: drop-shadow(0 12px 24px rgba(16, 185, 129, 0.4));
}

.logo h1 {
    background: linear-gradient(135deg, var(--accent-green) 0%, var(--accent-teal) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-size: 2.2rem;
    margin: 0;
    font-weight: 800;
    letter-spacing: -0.5px;
    transition: all var(--transition-normal);
}

.logo h1:hover {
    transform: scale(1.05);
}

.tagline {
    font-size: 1.1rem;
    color: var(--accent-teal);
    font-weight: 500;
    margin: 0;
    text-align: center;
}

/* Theme Toggle Button */
.theme-toggle {
    background: transparent;
    border: 2px solid var(--accent-blue);
    color: var(--text-primary);
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: 1.2rem;
    transition: all var(--transition-fast);
}

.theme-toggle:hover {
    background: var(--accent-blue);
    transform: scale(1.05);
}

/* ============================================
   Landing Section
   ============================================ */

.landing-section {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
    animation: fadeIn 0.6s ease-in;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.landing-section h2 {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-md);
    background: linear-gradient(135deg, var(--accent-green) 0%, var(--accent-blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.landing-section .subtitle {
    font-size: 1.3rem;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-xl);
}

.feature-highlights {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-lg);
    margin-top: var(--spacing-xl);
}

.feature {
    background: var(--bg-secondary);
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--bg-tertiary);
    transition: all var(--transition-normal);
    cursor: default;
}

.feature:hover {
    border-color: var(--accent-blue);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
}

.feature-icon {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-md);
}

.feature h3 {
    color: var(--accent-green);
    margin-bottom: var(--spacing-sm);
}

.feature p {
    font-size: 0.95rem;
    color: var(--text-tertiary);
}

/* ============================================
   Form Section & Progress Bar (Feature 10)
   ============================================ */

.form-section {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    border: 1px solid var(--bg-tertiary);
    box-shadow: var(--shadow-md);
}

.form-container h3 {
    color: var(--accent-teal);
    margin-bottom: var(--spacing-lg);
    border-bottom: 2px solid var(--accent-blue);
    padding-bottom: var(--spacing-md);
}

.form-progress {
    margin-bottom: var(--spacing-xl);
}

.progress-bar {
    height: 8px;
    background: var(--bg-tertiary);
    border-radius: var(--radius-sm);
    overflow: hidden;
    margin-bottom: var(--spacing-md);
}

.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-green) 0%, var(--accent-teal) 100%);
    transition: width 0.3s ease;
}

#progressText {
    font-size: 0.9rem;
    color: var(--accent-teal);
    font-weight: 600;
    margin: 0;
}

/* Salary Slider (Feature 3) */
.salary-slider-wrapper {
    display: flex;
    gap: var(--spacing-lg);
    align-items: center;
    margin: var(--spacing-lg) 0;
}

.salary-slider-wrapper input[type="range"] {
    flex: 1;
    height: 6px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--bg-primary);
    border-radius: var(--radius-sm);
    outline: none;
    -webkit-slider-thumb-appearance: none;
    appearance: none;
}

.salary-slider-wrapper input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-green) 0%, var(--accent-teal) 100%);
    cursor: pointer;
    box-shadow: 0 0 10px rgba(16, 185, 129, 0.3);
}

.salary-slider-wrapper input[type="range"]::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-green) 0%, var(--accent-teal) 100%);
    cursor: pointer;
    border: none;
    box-shadow: 0 0 10px rgba(16, 185, 129, 0.3);
}

.salary-slider-display {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    min-width: 150px;
}

.form-group {
    margin-bottom: var(--spacing-xl);
    border: none;
    padding: 0;
}

.form-group legend {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--accent-green);
    margin-bottom: var(--spacing-md);
    padding: 0;
}

.form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
}

.form-field {
    display: flex;
    flex-direction: column;
}

.form-field.full-width {
    grid-column: 1 / -1;
}

.form-field label {
    font-weight: 500;
    margin-bottom: var(--spacing-sm);
    color: var(--text-secondary);
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
}

.form-field input,
.form-field textarea,
.form-field select {
    padding: var(--spacing-md);
    border: 1px solid var(--bg-tertiary);
    border-radius: var(--radius-md);
    background-color: var(--bg-primary);
    color: var(--text-primary);
    font-size: 1rem;
    transition: all var(--transition-fast);
    font-family: inherit;
}

.form-field input::placeholder,
.form-field textarea::placeholder {
    color: var(--text-tertiary);
}

.form-field input:focus,
.form-field textarea:focus,
.form-field select:focus {
    outline: none;
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.form-field textarea {
    resize: vertical;
    min-height: 100px;
}

/* Tooltip (Feature 6) */
.tooltip {
    position: relative;
    cursor: help;
    border-bottom: 1px dotted var(--accent-blue);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: rgba(59, 130, 246, 0.2);
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: bold;
}

.tooltip:hover::after {
    content: attr(data-tooltip);
    position: absolute;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    bottom: 125%;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    z-index: 1000;
    border: 1px solid var(--accent-blue);
    box-shadow: var(--shadow-lg);
}

/* ============================================
   Buttons
   ============================================ */

.btn {
    padding: var(--spacing-md) var(--spacing-lg);
    border: none;
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-normal);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
}

.btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-primary {
    background: linear-gradient(135deg, var(--accent-green) 0%, var(--accent-teal) 100%);
    color: white;
    border: none;
}

.btn-primary:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.btn-secondary {
    background: var(--bg-tertiary);
    color: var(--accent-blue);
    border: 1px solid var(--accent-blue);
}

.btn-secondary:hover:not(:disabled) {
    background: var(--accent-blue);
    color: white;
}

.btn-tertiary {
    background: transparent;
    color: var(--text-tertiary);
    border: 1px solid var(--bg-tertiary);
}

.btn-tertiary:hover:not(:disabled) {
    border-color: var(--accent-blue);
    color: var(--accent-blue);
}

.btn-sm {
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: 0.9rem;
}

.form-actions {
    display: flex;
    gap: var(--spacing-md);
    margin-top: var(--spacing-xl);
    flex-wrap: wrap;
    justify-content: flex-start;
}

.form-actions button {
    flex: 1;
    min-width: 150px;
}

@media (max-width: 768px) {
    .form-actions {
        flex-direction: column;
    }
    
    .form-actions button {
        width: 100%;
    }
}

/* ============================================
   Loading State
   ============================================ */

.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-2xl);
    gap: var(--spacing-lg);
}

.loading-state.hidden {
    display: none;
}

.spinner {
    border: 4px solid var(--bg-tertiary);
    border-top-color: var(--accent-green);
    border-radius: 50%;
    width: 50px;
    height: 50px;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* ============================================
   Results Section
   ============================================ */

.results-section {
    animation: fadeIn 0.6s ease-in;
}

.results-section.hidden {
    display: none;
}

/* Recommendation Card */
.recommendation-card {
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
    border: 2px solid var(--accent-green);
    box-shadow: var(--shadow-lg);
}

.recommendation-content {
    display: flex;
    align-items: center;
    gap: var(--spacing-xl);
}

.recommendation-score {
    font-size: 4rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-green) 0%, var(--accent-teal) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    min-width: 150px;
    text-align: center;
}

.recommendation-text h3 {
    color: var(--accent-green);
    margin-bottom: var(--spacing-sm);
}

.recommendation-text p {
    color: var(--text-secondary);
}

/* Score Cards Grid */
.scores-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
}

.score-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    border: 1px solid var(--bg-tertiary);
    transition: all var(--transition-normal);
}

.score-card:hover {
    border-color: var(--accent-blue);
    transform: translateY(-2px);
}

.score-label {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: var(--spacing-sm);
}

.score-value {
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent-green);
    margin-bottom: var(--spacing-md);
}

.score-bar {
    height: 6px;
    background-color: var(--bg-primary);
    border-radius: var(--radius-sm);
    overflow: hidden;
}

.score-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-green) 0%, var(--accent-teal) 100%);
    border-radius: var(--radius-sm);
    transition: width var(--transition-slow);
}

/* Financial Section */
.financial-section {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    border: 1px solid var(--bg-tertiary);
    margin-bottom: var(--spacing-xl);
}

.financial-section h3 {
    color: var(--accent-teal);
    margin-bottom: var(--spacing-lg);
    border-bottom: 2px solid var(--accent-blue);
    padding-bottom: var(--spacing-md);
}

/* Salary Visualization (Feature 8) */
.salary-visualization {
    margin-bottom: var(--spacing-xl);
}

.salary-visualization h4 {
    color: var(--text-secondary);
    margin-bottom: var(--spacing-md);
}

.salary-bar {
    height: 40px;
    background: var(--bg-primary);
    border-radius: var(--radius-md);
    position: relative;
    margin: var(--spacing-lg) 0;
    border: 1px solid var(--accent-blue);
    display: flex;
    align-items: center;
}

.salary-range {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-green) 0%, var(--accent-teal) 100%);
    border-radius: var(--radius-md);
    position: relative;
    width: 100%;
}

.salary-point {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 60%;
    background: white;
    box-shadow: 0 0 10px rgba(0,0,0,0.5);
    border-radius: var(--radius-sm);
}

.financial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
}

.financial-item {
    background: var(--bg-primary);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--accent-blue);
}

.financial-item.highlight {
    border-left-color: var(--accent-green);
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(6, 182, 212, 0.05) 100%);
}

.financial-item label {
    display: block;
    font-size: 0.85rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: var(--spacing-sm);
}

.financial-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-green);
}

.investment-projections {
    margin-top: var(--spacing-xl);
}

.investment-projections h4 {
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
    font-size: 1.1rem;
}

.projections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--spacing-lg);
}

.projection {
    background: var(--bg-primary);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    text-align: center;
    border: 1px solid var(--accent-teal);
}

.projection-label {
    color: var(--text-tertiary);
    font-size: 0.9rem;
    margin-bottom: var(--spacing-md);
}

.projection-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-teal);
}

/* What-If Scenarios (Feature 4) */
.scenario-section {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    border: 1px solid var(--bg-tertiary);
    margin-bottom: var(--spacing-xl);
}

.scenario-section h3 {
    color: var(--accent-teal);
    margin-bottom: var(--spacing-md);
}

.scenario-buttons {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-md);
}

.scenario-buttons .btn {
    width: 100%;
}

/* Charts Section */
.charts-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
}

.chart-container {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-lg);
    border: 1px solid var(--bg-tertiary);
}

.chart-container.full-width {
    grid-column: 1 / -1;
}

.chart-container h4 {
    color: var(--accent-teal);
    margin-bottom: var(--spacing-lg);
    font-size: 1.1rem;
}

.chart-container canvas {
    max-height: 300px;
}

/* AI Summary */
.ai-summary-section {
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(6, 182, 212, 0.05) 100%);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    border: 1px solid var(--accent-teal);
    margin-bottom: var(--spacing-xl);
}

.ai-summary-section h3 {
    color: var(--accent-green);
    margin-bottom: var(--spacing-md);
}

.ai-summary-text {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin: 0;
}

/* Risk Section */
.risk-section {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    border: 1px solid var(--bg-tertiary);
    margin-bottom: var(--spacing-xl);
}

.risk-section h3 {
    color: var(--accent-teal);
    margin-bottom: var(--spacing-lg);
}

.risk-flags {
    display: grid;
    gap: var(--spacing-lg);
}

.risk-flag {
    background: var(--bg-primary);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    border-left: 4px solid var(--accent-orange);
    display: flex;
    gap: var(--spacing-lg);
    align-items: flex-start;
}

.risk-flag.warning {
    border-left-color: var(--warning);
}

.risk-flag.info {
    border-left-color: var(--info);
}

.risk-flag.danger {
    border-left-color: var(--danger);
}

.risk-flag-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
}

.risk-flag-content h5 {
    margin-bottom: var(--spacing-sm);
    color: var(--text-primary);
}

.risk-flag-content p {
    font-size: 0.95rem;
    color: var(--text-tertiary);
    margin: 0;
}

/* Skills Section */
.skills-section {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    border: 1px solid var(--bg-tertiary);
    margin-bottom: var(--spacing-xl);
}

.skills-section h3 {
    color: var(--accent-teal);
    margin-bottom: var(--spacing-lg);
}

.skills-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-lg);
}

.skill-item {
    background: var(--bg-primary);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--accent-blue);
    color: var(--text-secondary);
    text-align: center;
    transition: all var(--transition-normal);
}

.skill-item:hover {
    border-color: var(--accent-green);
    color: var(--accent-green);
    background: rgba(16, 185, 129, 0.05);
}

/* Adjacent Roles */
.adjacent-roles-section {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    border: 1px solid var(--bg-tertiary);
    margin-bottom: var(--spacing-xl);
}

.adjacent-roles-section h3 {
    color: var(--accent-teal);
    margin-bottom: var(--spacing-lg);
}

.roles-list {
    display: grid;
    gap: var(--spacing-lg);
}

.role-item {
    background: var(--bg-primary);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--accent-green);
    transition: all var(--transition-normal);
    cursor: default;
}

.role-item:hover {
    border-left-color: var(--accent-teal);
    transform: translateX(4px);
}

.role-item-title {
    font-weight: 600;
    color: var(--accent-green);
    margin-bottom: var(--spacing-sm);
}

.role-item-description {
    font-size: 0.95rem;
    color: var(--text-tertiary);
}

/* Comparison Section (Feature 2) */
.comparison-section {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    border: 1px solid var(--bg-tertiary);
    margin-bottom: var(--spacing-xl);
}

.comparison-section h3 {
    color: var(--accent-teal);
    margin-bottom: var(--spacing-lg);
}

#addComparisonBtn {
    margin-bottom: var(--spacing-lg);
}

.comparison-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-lg);
}

.comparison-card {
    background: var(--bg-primary);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    border: 2px solid var(--accent-teal);
    position: relative;
}

.comparison-card h4 {
    color: var(--accent-teal);
    margin-bottom: var(--spacing-sm);
}

.comparison-card p {
    color: var(--text-tertiary);
    font-size: 0.9rem;
    margin-bottom: var(--spacing-md);
}

.comparison-stat {
    display: flex;
    justify-content: space-between;
    margin: var(--spacing-md) 0;
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--bg-tertiary);
    font-size: 0.9rem;
}

.comparison-stat span {
    color: var(--text-tertiary);
}

.comparison-stat strong {
    color: var(--accent-green);
}

.comparison-card .btn {
    width: 100%;
    margin-top: var(--spacing-md);
}

/* Save Section (Feature 9) */
.save-section {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    border: 1px solid var(--bg-tertiary);
    margin-bottom: var(--spacing-xl);
    display: flex;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
}

.save-section .btn {
    flex: 1;
    min-width: 200px;
}

/* Results Actions */
.results-actions {
    display: flex;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
    flex-wrap: wrap;
}

.results-actions button {
    flex: 1;
    min-width: 150px;
}

@media (max-width: 768px) {
    .results-actions {
        flex-direction: column;
    }
    
    .results-actions button {
        width: 100%;
    }
}

/* Disclaimer */
.disclaimer {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(245, 158, 11, 0.05) 100%);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    text-align: center;
    margin-top: var(--spacing-xl);
}

.disclaimer p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0;
}

.scenario-detail {
    background: var(--bg-primary);
    border: 1px solid var(--accent-teal);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    margin-top: var(--spacing-md);
    animation: slideDown 0.3s ease;
}

.scenario-detail.hidden {
    display: none;
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ============================================
   Footer
   ============================================ */

.footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--bg-tertiary);
    padding: var(--spacing-xl);
    text-align: center;
    margin-top: var(--spacing-2xl);
    color: var(--text-tertiary);
}

.footer p {
    margin: 0;
    font-size: 0.9rem;
}

/* ============================================
   Responsive Design
   ============================================ */

@media (max-width: 768px) {
    :root {
        font-size: 14px;
    }
    
    h1 { font-size: 2rem; }
    h2 { font-size: 1.5rem; }
    h3 { font-size: 1.25rem; }
    
    .container {
        padding: var(--spacing-lg);
    }
    
    .recommendation-content {
        flex-direction: column;
        text-align: center;
    }
    
    .recommendation-score {
        font-size: 3rem;
    }
    
    .navbar {
        margin-bottom: var(--spacing-lg);
    }
    
    .navbar-content {
        align-items: center;
    }

    .logo {
        flex-direction: column;
        gap: 0.5rem;
    }

    .logo-img {
        height: 70px;
    }

    .logo h1 {
        font-size: 1.8rem;
    }
    
    .charts-section {
        grid-template-columns: 1fr;
    }
    
    .scores-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .form-row {
        grid-template-columns: 1fr;
    }
    
    .financial-grid {
        grid-template-columns: 1fr;
    }
    
    .feature-highlights {
        grid-template-columns: 1fr;
    }
    
    .salary-slider-wrapper {
        flex-direction: column;
        align-items: stretch;
    }
    
    .save-section {
        flex-direction: column;
    }
    
    .save-section .btn {
        width: 100%;
    }
}

@media (max-width: 480px) {
    .container {
        padding: var(--spacing-md);
    }
    
    h1 { font-size: 1.5rem; }
    h2 { font-size: 1.25rem; }
    h3 { font-size: 1.1rem; }
    
    .logo-img {
        height: 60px;
    }

    .logo h1 {
        font-size: 1.5rem;
    }
    
    .scores-grid {
        grid-template-columns: 1fr;
    }
    
    .projections-grid {
        grid-template-columns: 1fr;
    }
    
    .form-actions {
        flex-direction: column;
        gap: var(--spacing-sm);
    }
    
    .results-actions {
        flex-direction: column;
        gap: var(--spacing-sm);
    }
    
    .scenario-buttons {
        grid-template-columns: 1fr;
    }
}

/* ============================================
   Print Styles
   ============================================ */

@media print {
    body {
        background: white;
        color: black;
    }
    
    .navbar,
    .form-section,
    .form-actions,
    .results-actions,
    .footer,
    .theme-toggle {
        display: none;
    }
    
    .results-section {
        animation: none;
    }
}

/* ============================================
   INVESTMENT SUGGESTIONS - CARDS
   ============================================ */

.investment-suggestions {
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(6, 182, 212, 0.05) 100%);
    border: 2px solid var(--accent-green);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    margin-top: var(--spacing-xl);
}

.investment-suggestions h4 {
    color: var(--accent-green);
    margin-bottom: var(--spacing-xl);
    font-size: 1.3rem;
}

.investment-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--spacing-lg);
}

.investment-option {
    background: var(--bg-secondary);
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    border: 2px solid var(--accent-teal);
    transition: all var(--transition-normal);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.investment-option:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-xl);
    border-color: var(--accent-green);
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.05) 0%, rgba(6, 182, 212, 0.05) 100%);
}

.investment-icon {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-md);
}

.investment-name {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--accent-teal);
    margin-bottom: var(--spacing-sm);
}

.investment-desc {
    color: var(--text-tertiary);
    font-size: 0.9rem;
    margin-bottom: var(--spacing-lg);
    line-height: 1.5;
}

.investment-links {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    width: 100%;
}

.investment-links a {
    color: var(--accent-blue);
    text-decoration: none;
    font-size: 0.85rem;
    padding: var(--spacing-sm) var(--spacing-md);
    background: rgba(59, 130, 246, 0.15);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    border: 1px solid rgba(59, 130, 246, 0.3);
    font-weight: 500;
}

.investment-links a:hover {
    background: var(--accent-blue);
    color: white;
    border-color: var(--accent-blue);
    transform: translateX(2px);
}

/* Responsive */
@media (max-width: 768px) {
    .investment-options {
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }
    
    .investment-option {
        padding: var(--spacing-md);
    }
    
    .investment-icon {
        font-size: 2rem;
    }
}

@media (max-width: 480px) {
    .investment-options {
        grid-template-columns: 1fr;
    }
}